# --- NASA FIRMS (required) ---
# Get a free key at https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=

# --- AirNow (optional but recommended) ---
# Get a free key at https://docs.airnowapi.org/
AIRNOW_API_KEY=

# --- Center point for distance calculations ---
HOME_LAT=31.0381
HOME_LON=-83.3690
HOME_LABEL=Hahira, GA

# --- Coverage area (bbox for FIRMS queries; bigger than alert radius) ---
# (W, S, E, N) — covers Lowndes + neighbors + parts of north FL
BBOX_WEST=-84.5
BBOX_SOUTH=29.8
BBOX_EAST=-82.2
BBOX_NORTH=32.0

# --- Alert radii in miles ---
ALERT_RADIUS_URGENT=25
ALERT_RADIUS_EMAIL=50
ALERT_RADIUS_DASHBOARD=75

# --- NWS zones to monitor (Red Flag Warnings etc.) ---
# GAZ155 = Lowndes; add neighbors comma-separated
NWS_ZONES=GAZ155,GAZ153,GAZ154,GAZ156,GAZ157

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBERS=  # comma-separated E.164 numbers

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=     # Gmail App Password, not your real password
SMTP_FROM=
SMTP_TO=           # comma-separated

# --- App ---
DATABASE_PATH=./firewatcher.db
LOG_LEVEL=INFO

# --- Frontend / AdSense (Vite reads VITE_* at build time) ---
# Get your publisher ID from https://adsense.google.com after site approval.
# Format: ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_PUBLISHER_ID=
VITE_ADSENSE_AD_SLOT=
